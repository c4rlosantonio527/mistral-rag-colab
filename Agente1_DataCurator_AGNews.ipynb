    {
      "cell_type": "code",
      "source": [
        "# Verificación del mapeo de categorías\n",
        "print(\"=== DISTRIBUCIÓN DE CATEGORÍAS ===\")\n",
        "print(df_train[\"category_name\"].value_counts())\n",
        "print(f\"\\nVerificación de consistencia label <-> category_name:\")\n",
        "mismatch = (df_train[\"category_name\"] != df_train[\"label\"].map(LABEL_MAP)).sum()\n",
        "if mismatch == 0:\n",
        "    print(\"✓ Todos los mapeos son correctos\")\n",
